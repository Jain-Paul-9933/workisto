# Copy this file to `.env` and adjust. `.env` is git-ignored; this template is committed.

# --- Django ---
DJANGO_SECRET_KEY=dev-only-change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Postgres / PostGIS (these are read by BOTH the db container and Django) ---
POSTGRES_DB=homeservices
POSTGRES_USER=homeservices
POSTGRES_PASSWORD=homeservices
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis (channels /0, celery broker /1, celery results /2, cache+sessions /3) ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
CACHE_URL=redis://redis:6379/3
